# Anthropic API — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Instagram Graph API — developers.facebook.com
# Long-lived Page Access Token (válido ~60 días, renovar con cron o token infinito via system user)
INSTAGRAM_ACCESS_TOKEN=EAAxxxxx...
# Instagram Business Account ID (ve a Meta Business Suite → Configuración → Cuentas de Instagram)
INSTAGRAM_ACCOUNT_ID=17841xxxxxxx

# GitHub (sólo necesario en local; en Actions se inyecta automáticamente)
GITHUB_REPOSITORY=porveniragenciadigital/instagram-bot
